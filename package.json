{
  "name": "@stcn52/cloud-ui",
  "version": "0.3.0",
  "description": "NextCli design system — React + TS component library with Tailwind v4.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "tsc -b tsconfig.build.json && vite build",
    "build-storybook": "storybook build",
    "typecheck": "tsc -b && tsc -p tsconfig.stories.json"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "typescript",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stcn52/cloud-ui.git"
  },
  "homepage": "https://github.com/stcn52/cloud-ui#readme",
  "bugs": {
    "url": "https://github.com/stcn52/cloud-ui/issues"
  },
  "license": "MIT",
  "dependencies": {
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
