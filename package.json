{
  "name": "@stcn52/cloud-ui",
  "version": "0.1.0",
  "description": "NextCli design system — React + TS component library with Tailwind v4.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.build.json && BUILD_MODE=lib vite build",
    "build:playground": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b && tsc -p tsconfig.playground.json"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "typescript",
    "tailwindcss"
  ],
  "license": "MIT",
  "dependencies": {
    "tailwind-variants": "^3.2.2"
  }
}
